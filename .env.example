# ============================================
# LexIntellectus ERP - Environment Variables
# ============================================

# --- PostgreSQL ---
POSTGRES_USER=lexintellectus
POSTGRES_PASSWORD=lexintellectus_dev_2026
POSTGRES_DB=lexintellectus
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://lexintellectus:lexintellectus_dev_2026@localhost:5432/lexintellectus

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=lexintellectus_redis_2026
REDIS_URL=redis://:lexintellectus_redis_2026@localhost:6379/0

# --- MinIO (S3-Compatible Storage) ---
MINIO_ROOT_USER=lexintellectus
MINIO_ROOT_PASSWORD=lexintellectus_minio_2026
MINIO_ENDPOINT=localhost:9000
MINIO_BUCKET=lexintellectus-documents
MINIO_USE_SSL=false

# --- JWT / Auth ---
JWT_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_SECRET_KEY_IN_PRODUCTION
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- App ---
APP_NAME=LexIntellectus
APP_VERSION=0.1.0
APP_ENV=development
APP_DEBUG=true
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# --- API ---
API_V1_PREFIX=/api/v1
